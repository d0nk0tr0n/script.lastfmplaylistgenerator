<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="script.lastfmplaylistgenerator"
       name="last.fm Playlist Generator"
       version="1.3.2.3"
       provider-name="d0nk0tr0n">
  <requires>
    <import addon="script.module.simplejson" version="3.19.1" />
    <import addon="xbmc.python" version="3.0.1" />
  </requires>
  <extension point="xbmc.python.script"
             library="default.py">
    <provides>audio</provides>
  </extension> 
  <extension point="xbmc.addon.metadata">
    <website>https://github.com/d0nk0tr0n/script.lastfmplaylistgenerator</website>
    <source>https://github.com/d0nk0tr0n/script.lastfmplaylistgenerator</source>
    <license>GPL-2.0-only</license>
    <platform>all</platform>
    <summary lang="en_GB">last.fm Playlist Generator</summary>
    <description lang="en_GB">Create smart playlists with the help of last.fm</description>
    <assets>
        <icon>icon.png</icon>
        <fanart>fanart.jpg</fanart>
    </assets>
  </extension>
</addon>
