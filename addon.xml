<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="script.lastfmplaylistgenerator"
       name="Last.FM Playlist Generator"
       version="1.3.1.2"
       provider-name="d0nk0tr0n">
  <requires>
    <import addon="script.module.simplejson" version="3.19.1" />
    <import addon="xbmc.python" version="3.0.1" />
  </requires>
  <extension point="xbmc.python.script"
             library="default.py">
    <provides>audio</provides>
  </extension> 
  <extension point="xbmc.addon.metadata">
    <website>https://github.com/d0nk0tr0n/script.lastfmplaylistgenerator.git</website>
    <platform>all</platform>
    <summary>Last.FM Playlist Generator</summary>
    <description>Create smart playlists with the help of Last.FM</description>
    <assets>
      <icon>icon.png</icon>
    </assets>
  </extension>
</addon>
